  "jetson-orin-nano-devkit": {
    "name": "NVIDIA Jetson Orin Nano",
    "target": "jetson-orin-nano-devkit",
    "category": "tegraflash",
    "description": "The Jetson is provisioned over USB using NVIDIA's tegraflash tooling, which runs inside the Avocado SDK container.",
    "provisioning": {
      "profile": "tegraflash",
      "media": "NVMe SSD (M.2 2280)",
      "hostOs": ["Linux"],
      "prerequisites": [
        "NVIDIA Jetson Orin Nano Developer Kit",
        "NVMe SSD (M.2 2280 form factor)",
        "Linux host machine (Ubuntu 22.04+, Fedora 39+)",
        "16 GB available disk space",
        "USB-C cable for provisioning (host USB to Jetson USB-C)",
        "TTY serial console USB adapter (3.3V)"
      ],
      "provisionCommand": "avocado provision -r dev --profile tegraflash",
      "provisionDescription": "Provision the dev runtime using the tegraflash profile. This builds the system image and flashes it to the Jetson over USB.",
      "provisionSteps": [
        { "type": "text", "content": "The procedure advances through several steps:" },
        {
          "type": "code",
          "content": "== Step 1: Signing binaries ==\n...\n== Step 2: Boot Jetson via RCM ==\n...\n== Step 3: Sending flash sequence commands ==\n..."
        },
        { "type": "text", "content": "When provisioning completes:" },
        { "type": "code", "content": "[SUCCESS] Successfully provisioned runtime 'dev'" }
      ],
      "bootSteps": [
        "Remove power from the Jetson",
        "Remove the jumper shorting FC REC to GND",
        "Remove the USB-C cable",
        "Leave the serial console adapter connected",
        "Apply power"
      ],
      "bootNote": "The device will boot with the provisioned system. Log in as root with an empty password via the serial console.",
      "recoveryMode": {
        "steps": [
          "With the device powered off, short the FC REC pin to GND using a jumper",
          "Connect the USB-C cable from the Jetson to your host machine",
          "Apply power to the Jetson"
        ],
        "verifyCommand": "lsusb",
        "verifyExpect": "Look for an entry containing NVIDIA Corp. APX — this confirms the device is in recovery mode."
      },
      "warnings": ["linuxAutoMount", "linuxHostOnly"]
    },
    "serial": {
      "baud": 115200,
      "voltage": "3.3V",
      "command": "tio -b 115200 /dev/ttyUSB0",
      "image": {
        "src": "/img/jetson-orin-nano-devkit-serial-console.gif",
        "alt": "Jetson Orin Nano DevKit Serial Console"
      },
      "gpio": [
        {
          "color": "#cccc00",
          "label": "yellow",
          "pin": "FC REC",
          "to": "GND",
          "note": "recovery mode"
        },
        { "color": "#000000", "label": "black", "pin": "GND", "to": "UART GND" },
        { "color": "#00aa00", "label": "green", "pin": "UART TXD", "to": "adapter UART RX" },
        { "color": "#0000cc", "label": "blue", "pin": "UART RXD", "to": "adapter UART TX" }
      ]
    },
    "gettingStartedUrl": "/developer-reference/getting-started/jetson",
    "hardwareUrl": "/hardware/nvidia/jetson-orin-nano-developer-kit"
  },
